# ============================================================
# .env.example - Plantilla. Copiar a .env y completar.
# El archivo .env NO se sube a git (esta en .gitignore).
# ============================================================

# --- Servidor ---
HOST=127.0.0.1
PORT=8001
ROOT_PATH=/model

# --- JWT (GENERAR CON: openssl rand -hex 32) ---
JWT_SECRET_KEY=GENERAR-CON-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Modo operativo ---
# Valores: shadow | piloto | produccion
OPERATION_MODE=shadow

# --- Umbrales (opcional, sobreescriben los defaults de config.py) ---
# UMBRAL_MEJORA_VS_BASELINE=0.15
# UMBRAL_DRIFT_DATA_PVALUE=0.01
# UMBRAL_DRIFT_MODEL_RATIO=1.20
